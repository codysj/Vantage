# Required: main database connection. Postgres is the default prod/local container target.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/information_edge

# Optional: Polymarket data sources.
POLYMARKET_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_EVENTS_PATH=/events
POLYMARKET_TRADES_BASE_URL=https://data-api.polymarket.com
POLYMARKET_TRADES_PATH=/trades
POLYMARKET_ACTIVE=true
POLYMARKET_CLOSED=false
POLYMARKET_LIMIT=50
POLYMARKET_TRADES_LIMIT=500
POLYMARKET_TRADES_BATCH_SIZE=25
POLYMARKET_TIMEOUT_SECONDS=15

# Optional: ingestion and scheduler behavior.
PIPELINE_INTERVAL_SECONDS=300
PIPELINE_LOG_LEVEL=INFO
PIPELINE_LOG_TO_FILE=false
PIPELINE_LOG_FILE=logs/pipeline.log
PIPELINE_MAX_RETRIES=2
PIPELINE_MISFIRE_GRACE_SECONDS=30
PIPELINE_CONTINUOUS_DEFAULT=false

# Optional: rule-based signal thresholds.
SIGNAL_PRICE_THRESHOLD=0.10
SIGNAL_VOLUME_MULTIPLIER=3.0
SIGNAL_LIQUIDITY_THRESHOLD=0.20
SIGNAL_LOOKBACK_WINDOW_MINUTES=30

# Optional: whale detector thresholds.
WHALE_MIN_HISTORY_COUNT=20
WHALE_BASELINE_TRADE_COUNT=100
WHALE_ZSCORE_THRESHOLD=3.0
WHALE_MEDIAN_MULTIPLIER_THRESHOLD=5.0
WHALE_ABSOLUTE_MIN_NOTIONAL=250

# Optional: sentiment enrichment. Leave GNEWS_API_KEY blank to disable on-demand sentiment.
GNEWS_API_KEY=
GNEWS_BASE_URL=https://gnews.io/api/v4
GNEWS_SEARCH_PATH=/search
SENTIMENT_TTL_HOURS=4
SENTIMENT_MAX_DOCS_PER_MARKET=10
SENTIMENT_MODEL_NAME=cardiffnlp/twitter-roberta-base-sentiment-latest
SENTIMENT_REQUEST_TIMEOUT_SECONDS=15

# Optional: allowed frontend origins for local/browser access.
API_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
